{
    "$schema":  "https://schema.tauri.app/config/2",
    "identifier":  "dev.soulkernel.app",
    "productName":  "SoulKernel",
    "version":  "1.1.6",
    "build":  {
                  "beforeBuildCommand":  {
                                            "script":  "npm run build",
                                            "cwd":  "ui"
                                        },
                  "beforeDevCommand":  {
                                           "script":  "npm run dev",
                                           "cwd":  "ui"
                                       },
                  "devUrl":  "http://localhost:5173",
                  "frontendDist":  "ui/dist"
              },
    "app":  {
                "withGlobalTauri":  true,
                "security":  {
                                 "csp":  null
                             },
                "windows":  [
                                {
                                    "fullscreen":  false,
                                    "height":  800,
                                    "resizable":  true,
                                    "title":  "SoulKernel",
                                    "width":  1200
                                }
                            ]
            },
    "bundle":  {
                   "active":  true,
                   "resources": [
                                     "scripts/meross_mss315_bridge.py",
                                     "runtime/python"
                                 ],
                   "icon":  [
                                "icons/png/icon_16x16.png",
                                "icons/png/icon_24x24.png",
                                "icons/png/icon_32x32.png",
                                "icons/png/icon_48x48.png",
                                "icons/png/icon_64x64.png",
                                "icons/png/icon_96x96.png",
                                "icons/png/icon_128x128.png",
                                "icons/png/icon_180x180.png",
                                "icons/png/icon_192x192.png",
                                "icons/png/icon_256x256.png",
                                "icons/png/icon_512x512.png",
                                "icons/png/icon_1024x1024.png",
                                "icons/icns/icon.icns",
                                "icons/ico/icon.ico",
                                "icons/linux/hicolor/16x16/apps/soulkernel.png",
                                "icons/linux/hicolor/24x24/apps/soulkernel.png",
                                "icons/linux/hicolor/32x32/apps/soulkernel.png",
                                "icons/linux/hicolor/48x48/apps/soulkernel.png",
                                "icons/linux/hicolor/64x64/apps/soulkernel.png",
                                "icons/linux/hicolor/96x96/apps/soulkernel.png",
                                "icons/linux/hicolor/128x128/apps/soulkernel.png",
                                "icons/linux/hicolor/256x256/apps/soulkernel.png",
                                "icons/linux/hicolor/512x512/apps/soulkernel.png"
                            ],
                   "shortDescription":  "Orchestrateur Performance Dome — priorise votre processus, prouve les gains.",
                   "longDescription":  "SoulKernel pilote les paramètres noyau (CPU, RAM, I/O) pour donner un maximum d\u0027amplitude au processus cible. Export des gains et comparaison avant/après pour prouver l\u0027effet."
               },
    "plugins":  {

                }
}
