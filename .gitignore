# --- Build artifacts ---
/target/
**/*.rs.bk

# --- Rust/Cargo ---
# Keep Cargo.lock for application crates
# /Cargo.lock

# --- Tauri / frontend outputs ---
/src-tauri/target/
/dist/
/build/
/ui/node_modules/
/ui/dist/

# --- Logs / runtime data ---
*.log
*.tmp
*.cache
/runtime/python/*
!/runtime/python/README.md

# --- Local helper/generated scratch files ---
.tmp_*.js
.tmp_*.ts
.tmp_*.json
soulkernel_gains_*.json
# Échantillons télémétrie / énergie locaux (ne pas versionner)
soulkernel_energy_samples.jsonl
nul
# Wrapper MSVC local (voir scripts/cargo-msvc.example.cmd)
/cargo-msvc.cmd

# --- IDE / editor ---
.vscode/
.idea/
# Cursor : état local ignoré ; on versionne mcp.json, README MCP et rules/
.cursor/*
!.cursor/mcp.json
!.cursor/README-MCP.md
!.cursor/rules/

# --- Windows ---
Thumbs.db
Desktop.ini

# --- Env / secrets ---
.env
.env.*
!.env.example
